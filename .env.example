# Cafe Empire — Mobile App Environment Variables
# Copy this file to .env and fill in your values.

# Laravel backend base URL
# Local development: use your machine's IP so physical devices can connect
# Production: use your deployed API URL
EXPO_PUBLIC_BACKEND_URL=http://127.0.0.1:8000

# Outlet / branch ID to scope the app to
EXPO_PUBLIC_OUTLET_ID=1
