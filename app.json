{
  "expo": {
    "name": "Cafe Empire",
    "slug": "cafe-empire",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/cafe-system-logo.png",
    "scheme": "cafeempire",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.khmerempire.cafeempire",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/cafe-system-logo.png",
        "backgroundColor": "#000"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/cafe-system-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/cafe-system-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9896ac1d-dd05-4bc9-9b41-b10aa1979ebc"
      }
    },
    "owner": "khmer-empire"
  }
}
