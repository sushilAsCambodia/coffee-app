  "layout_guidelines": {
    "screen_structure": {
      "safe_area": "ALWAYS use SafeAreaView or useSafeAreaInsets for top/bottom padding.",
      "padding_horizontal": 20,
      "bottom_tab_height": 60
    },
    "navigation": {
      "type": "Expo Router (Stack + Tabs)",
      "animation": "slide_from_right",
      "header": {
        "backgroundColor": "#faf8f5",
        "tintColor": "#6f4e37",
        "titleStyle": { "fontFamily": "System Serif", "fontWeight": "bold", "color": "#3d2817" }
      }
    }
  },
  "motion_guidelines": {
    "library": "react-native-reanimated",
    "transitions": {
      "press": "Scale down to 0.98 on press using useAnimatedStyle",
      "entry": "FadeInDown.duration(400) for lists and cards",
      "modal": "SlideInUp for bottom sheets"
    }
  },
  "specific_screens": {
    "LoginScreen": {
      "layout": "Full screen background image (hero_barista) with heavy overlay (rgba(61,40,23,0.8)). Content centered. Gold accents.",
      "elements": ["Logo (large)", "Google Button (white)", "Email/Pass Input (transparent bg, white border)"]
    },
    "HomeScreen": {
      "layout": "Header with Greeting & Cart Icon. Horizontal Scroll Categories (Pills). Vertical Grid Best Sellers.",
      "categories": "Pill shape, inactive bg #ede5dc, active bg #6f4e37."
    },
    "ProductDetail": {
      "layout": "Parallax Header Image (50% height). White Bottom Sheet with negative margin top (-40px) and rounded top corners (30px).",
      "interaction": "Add to Cart button fixed at bottom."
    },
    "TrackingScreen": {
      "layout": "Map view takes 65% height. Floating Driver Card at bottom (Glassmorphism style or solid white shadow).",
      "map_style": "Custom JSON style to match cream/brown theme if possible, else standard."
    }
  },
  "instructions_to_main_agent": [
    "CRITICAL: DO NOT use Tailwind CSS classes. Use StyleSheet.create().",
    "CRITICAL: Use @expo/vector-icons for all icons (Ionicons preferred).",
    "CRITICAL: Ensure all TouchableOpacity/Pressable have a minimum hit slop of 10.",
    "CRITICAL: Use 'expo-image' for optimized image loading with blurhash if possible.",
    "CRITICAL: Handle 'KeyboardAvoidingView' behavior on Login and Checkout screens.",
    "CRITICAL: Use data-testid on all interactive elements for testing."
  ],
  "UNIVERSAL_GUIDELINES": [
    "Avoid using pure black (#000000). Use #3d2817 (Coffee Dark) for text.",
    "Touch targets must be at least 44x44 points.",
    "Use distinct Visual Feedback on press (opacity change or scale).",
    "Loading states must use skeletons, not just spinners.",
    "Error states must use the 'destructive' color (#c44536) with clear text."
  ]
}